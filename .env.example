# -------- WildSnap environment --------
# Copy the values you need into apps/web/.env.local (web) and set the mobile
# variable in your Expo environment. NEVER commit real keys.

# --- Web (apps/web/.env.local) ---

# Your Anthropic API key. Required for real identification (milestone M3+).
# The web app only reads this SERVER-SIDE, inside /api/identify — it is never
# exposed to the browser. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Which Claude vision model to use. Defaults to claude-sonnet-5.
#   claude-haiku-4-5  -> cheapest
#   claude-sonnet-5   -> balanced quality/cost (default)
#   claude-opus-4-8   -> highest quality
VISION_MODEL=claude-sonnet-5

# --- Mobile (Expo env, milestone M4) ---

# URL of the web app's /api/identify route. The mobile app posts photos here so
# the Anthropic key never ships inside the mobile bundle. Use your dev machine's
# LAN address when testing on a physical phone, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_IDENTIFY_URL=http://localhost:3000/api/identify
